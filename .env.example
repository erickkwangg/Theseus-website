# Resend — playground waitlist signup
# Create an API key at https://resend.com/api-keys
# Find your segment ID at https://resend.com/audience (Segments tab)
# Without these, notify.ts logs to console and returns success (for dev).
RESEND_API_KEY=
RESEND_SEGMENT_ID=

# Proof of Agenthood — Ed25519 signing key for issued credentials.
# Generate with: npm run poa:keygen
# Then paste the printed line into .env.local (do not commit).
POA_SIGNING_KEY_JWK=

# Optional: base URL used in revocation list pointers inside credentials.
POA_BASE_URL=

# Theseus Chain RPC — set to use the real chain instead of fixtures.
# Local devnet (after `cargo run --release -- --dev` in theseus-chain repo):
#   THESEUS_RPC_URL=ws://localhost:9944
# Unset = fixture mode (three demo agents, no chain connection required).
# When set, connection / decode failures fail loud (HTTP 503 on API endpoints,
# error banner on pages) — there is no silent fallback to fixtures.
THESEUS_RPC_URL=

# Vercel KV (Redis) — credential and challenge persistence.
# Auto-provisioned by Vercel when you enable the KV / Storage integration on
# the project; do not set these manually for production deploys. Vercel will
# inject KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN.
# Unset = in-memory mode (state resets per cold start; fine for local dev,
# unsafe for production). Same fail-loud rule as the chain reader: when set,
# Redis errors propagate as 503 rather than silently falling back to memory.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# DeepSeek — powers the in-page agent demos at /poa/<id>/demo. The five
# demos call /api/poa/demo/<slug> which routes through deepseek-chat with
# the agent's THESEUS.md identity in the system message. Unset = scripted
# fallback (the demos still work; the responses are pre-baked).
# DeepSeek is OpenAI-compatible; the openai SDK is pointed at their base
# URL. Get a key at https://platform.deepseek.com.
DEEPSEEK_API_KEY=
